# ===== Application =====
APP_NAME=GoldPredictor
APP_ENV=development
DEBUG=true

# ===== Database =====
# SQLite (development)
DATABASE_URL=sqlite:///./data/gold_predictor.db

# PostgreSQL (production) - uncomment when ready
# DATABASE_URL=postgresql://user:password@localhost:5432/gold_predictor

# ===== AI Reasoning =====
# Google Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# DeepSeek API (https://platform.deepseek.com/) - backup AI
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ===== Data Collection APIs =====
# Alpha Vantage API (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=

# FRED API (https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# ===== Data Collection Resilience =====
COLLECTOR_MAX_RETRIES=3
COLLECTOR_RETRY_DELAY=2.0
ALPHA_VANTAGE_CALL_DELAY=15.0

# ===== Data Collection =====
# SJC scraping interval (minutes)
SJC_SCRAPE_INTERVAL=60

# Historical data years to collect
HISTORICAL_YEARS=5

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== Scheduler =====
# Daily data collection time (HH:MM)
DAILY_COLLECT_TIME=08:00
# Weekly model retrain day (0=Monday, 6=Sunday)
WEEKLY_RETRAIN_DAY=0
